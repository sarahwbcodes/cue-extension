{
  "name": "cue",
  "displayName": "Cue",
  "version": "0.0.1",
  "description": "Reads your active tab and surfaces the one most tedious thing to do next — with a single button to do it.",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "plasmo": "^0.90.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "typescript": "^5.3.3"
  },
  "manifest": {
    "host_permissions": ["<all_urls>"],
    "permissions": ["activeTab", "scripting", "storage"]
  }
}
